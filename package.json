		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-preprocess": "^6.0.3",
		"sveltekit-embed": "^0.0.22",
		"tailwindcss": "^4.1.17",
